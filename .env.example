# Konfigurasi aplikasi StrokeMonitor
# Salin file ini menjadi .env dan sesuaikan nilainya

# ID pasien di Firebase Firestore
USER_ID=patient_001

# Jeda minimum antar pengiriman sinyal yang sama (detik)
COOLDOWN_SECONDS=60

# Path ke file model dan label (relatif dari root project)
MODEL_PATH=models/model.tflite
LABEL_PATH=models/labels.npy

# Path ke Firebase service account credentials
FIREBASE_CRED_PATH=config/firebase_credentials.json

# Host dan port server
HOST=0.0.0.0
PORT=8000
